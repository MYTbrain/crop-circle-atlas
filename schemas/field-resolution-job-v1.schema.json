{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crop-circle-atlas.example/schemas/field-resolution-job-v1.schema.json",
  "title": "Field resolution job",
  "type": "object",
  "required": ["schema_version", "job_id", "formation_id", "source_assertion_ids", "reported_date", "locality_text", "clues", "search_polygons", "created_at", "updated_at", "software", "state"],
  "properties": {
    "schema_version": {"const": "crop-circle-atlas/field-resolution-job/v1"},
    "job_id": {"type": "string", "pattern": "^frj_[a-f0-9]{20}$"},
    "formation_id": {"type": "string", "minLength": 1},
    "source_assertion_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "reported_date": {"type": "object", "required": ["start", "end"], "properties": {"start": {"type": ["string", "null"]}, "end": {"type": ["string", "null"]}}, "additionalProperties": false},
    "locality_text": {"type": "string"},
    "clues": {"type": "array", "items": {"$ref": "#/$defs/clue"}},
    "search_polygons": {"type": "array", "items": {"$ref": "#/$defs/searchPolygon"}},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "software": {"type": "object", "required": ["component", "version"], "additionalProperties": {"type": "string"}},
    "state": {"enum": ["queued", "clues_extracted", "search_area_ready", "imagery_cataloged", "tiles_generated", "candidates_ranked", "registrations_proposed", "review_required", "rejected", "deferred", "unresolved", "candidate_field", "corroborated_field", "registered_site", "publication_eligible"]},
    "previous_job_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "artifacts": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string"}}},
    "warnings": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "citation": {"type": "object", "required": ["source_url"], "properties": {"source_url": {"type": "string"}, "assertion_id": {"type": ["string", "null"]}, "quote_hash": {"type": ["string", "null"], "pattern": "^$|^[a-f0-9]{64}$"}}, "additionalProperties": false},
    "clue": {"type": "object", "required": ["kind", "value", "confidence", "citations", "qualifiers"], "properties": {"kind": {"enum": ["city", "town", "township", "county", "state", "country", "farm", "ranch", "airport", "school", "college", "named_property", "road", "intersection", "river", "canal", "lake", "drainage", "bridge", "power_line", "utility_corridor", "railroad", "building", "field_dimension", "formation_dimension", "bearing", "directional_language", "elevation", "terrain", "report_date", "image_date", "other"]}, "value": {"type": "string", "minLength": 1}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "citations": {"type": "array", "items": {"$ref": "#/$defs/citation"}}, "qualifiers": {"type": "object"}}, "additionalProperties": false},
    "searchPolygon": {"type": "object", "required": ["polygon_id", "geometry", "role", "provider", "query", "exclusions", "area_sq_km", "admin_context"], "properties": {"polygon_id": {"type": "string"}, "geometry": {"$ref": "#/$defs/polygon"}, "role": {"const": "locality_search_area"}, "provider": {"type": "string"}, "query": {"type": "string"}, "exclusions": {"type": "array", "items": {"$ref": "#/$defs/polygon"}}, "area_sq_km": {"type": "number", "exclusiveMinimum": 0}, "admin_context": {"type": "object", "additionalProperties": {"type": "string"}}}, "additionalProperties": false},
    "polygon": {"type": "object", "required": ["type", "coordinates"], "properties": {"type": {"const": "Polygon"}, "coordinates": {"type": "array", "minItems": 1}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
