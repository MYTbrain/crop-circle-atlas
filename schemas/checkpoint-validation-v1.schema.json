{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crop-circle-atlas.example/schemas/checkpoint-validation-v1.schema.json",
  "title": "Independent checkpoint validation",
  "type": "object",
  "required": ["schema_version", "validation_id", "registration_candidate_id", "controls", "checkpoints", "metrics", "spatial_distribution", "reviewer", "validated_at", "result"],
  "properties": {
    "schema_version": {"const": "crop-circle-atlas/checkpoint-validation/v1"}, "validation_id": {"type": "string"}, "registration_candidate_id": {"type": "string"}, "controls": {"type": "array", "items": {"$ref": "#/$defs/landmark"}}, "checkpoints": {"type": "array", "items": {"$ref": "#/$defs/landmark"}},
    "metrics": {"type": "object", "required": ["errors_m", "median_m", "rmse_m", "maximum_m", "p95_m"], "properties": {"errors_m": {"type": "array", "items": {"type": "number", "minimum": 0}}, "median_m": {"type": "number", "minimum": 0}, "rmse_m": {"type": "number", "minimum": 0}, "maximum_m": {"type": "number", "minimum": 0}, "p95_m": {"type": "number", "minimum": 0}}, "additionalProperties": false}, "spatial_distribution": {"type": "object"}, "reviewer": {"type": "string", "minLength": 1}, "validated_at": {"type": "string", "format": "date-time"}, "result": {"enum": ["pass", "downgrade", "reject"]}, "homography": {"type": "array", "minItems": 3, "maxItems": 3}, "target_crs": {"type": "string"}, "uncertainty": {"type": "object"}
  },
  "$defs": {"landmark": {"type": "object", "required": ["landmark_id", "role", "description", "source_pixel", "map_coordinate", "reference_imagery_id", "landmark_uncertainty_m"], "properties": {"landmark_id": {"type": "string"}, "role": {"enum": ["control", "checkpoint"]}, "description": {"type": "string"}, "source_pixel": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "number"}}, "map_coordinate": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "number"}}, "predicted_map_coordinate": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "number"}}, "reference_imagery_id": {"type": "string"}, "landmark_uncertainty_m": {"type": "number", "minimum": 0}, "error_m": {"type": ["number", "null"], "minimum": 0}}, "additionalProperties": false}}, "additionalProperties": false
}
